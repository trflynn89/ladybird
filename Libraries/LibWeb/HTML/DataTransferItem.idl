callback FunctionStringCallback = undefined (Utf16DOMString data);

// https://html.spec.whatwg.org/multipage/dnd.html#datatransferitem
[Exposed=Window]
interface DataTransferItem {
    readonly attribute Utf16DOMString kind;
    readonly attribute Utf16DOMString type;
    undefined getAsString(FunctionStringCallback? _callback);
    File? getAsFile();

    // https://wicg.github.io/entries-api/#dom-datatransferitem-webkitgetasentry
    FileSystemEntry? webkitGetAsEntry();
};
