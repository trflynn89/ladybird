// https://html.spec.whatwg.org/multipage/interaction.html#commandevent
[Exposed=Window]
interface CommandEvent : Event {
    constructor([Utf16FlyString] Utf16DOMString type, optional CommandEventInit eventInitDict = {});
    readonly attribute Element? source;
    readonly attribute Utf16DOMString command;
};

dictionary CommandEventInit : EventInit {
    Element? source = null;
    Utf16DOMString command = "";
};
