[MissingValueDefault=auto, InvalidValueDefault=auto]
enum ClosedByAttribute {
    "any",
    "closerequest",
    "none"
};

// https://html.spec.whatwg.org/multipage/semantics.html#htmldialogelement
[Exposed=Window]
interface HTMLDialogElement : HTMLElement {

    [HTMLConstructor] constructor();

    [CEReactions, Reflect] attribute boolean open;
    attribute Utf16DOMString returnValue;
    [CEReactions, Reflect=closedby, Enumerated=ClosedByAttribute] attribute Utf16DOMString closedBy;
    [CEReactions] undefined show();
    [CEReactions] undefined showModal();
    [CEReactions] undefined close(optional Utf16DOMString returnValue);
    [CEReactions] undefined requestClose(optional Utf16DOMString returnValue);

};
